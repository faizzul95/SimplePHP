# Disable directory browsing
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to sensitive folders
    RewriteRule ^(app|systems|storage|logs|db)/ - [F,L,NC]
    # Prevent direct access to PHP files except index.php
    RewriteCond %{REQUEST_URI} !/index\.php$ [NC]
    RewriteCond %{THE_REQUEST} \s/+[^\s?]+\.php[\s?] [NC]
    RewriteRule ^ - [F,L]

    # Route all non-file and non-directory requests to front controller
    RewriteRule ^$ index.php [L,QSA]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)$ index.php?__route=$1 [L,QSA]
</IfModule>