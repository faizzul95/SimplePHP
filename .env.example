APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Kuala_Lumpur
APP_KEY=
APP_ERROR_LOG_PATH=logs/error.log

# Security
CSRF_PROTECTION=true
CSRF_TOKEN_NAME=csrf_token
CSRF_COOKIE_NAME=csrf_cookie
CSRF_EXPIRE=7200
CSRF_REGENERATE=false
CSRF_SECURE_COOKIE=false

# Database (Laravel-style)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=example_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Optional per-environment DB overrides
DB_STAGING_CONNECTION=mysql
DB_STAGING_HOST=localhost
DB_STAGING_PORT=3306
DB_STAGING_DATABASE=
DB_STAGING_USERNAME=
DB_STAGING_PASSWORD=
DB_STAGING_CHARSET=utf8mb4

DB_PRODUCTION_CONNECTION=mysql
DB_PRODUCTION_HOST=localhost
DB_PRODUCTION_PORT=3306
DB_PRODUCTION_DATABASE=
DB_PRODUCTION_USERNAME=
DB_PRODUCTION_PASSWORD=
DB_PRODUCTION_CHARSET=utf8mb4

DB_PROFILING_ENABLED=false
DB_CACHE_ENABLED=false
DB_CACHE_TTL=120
DB_CACHE_PATH=

# API
API_AUTH_REQUIRED=true
API_AUTH_METHODS=token
API_VERSIONING_ENABLED=true
API_VERSION=v1
API_PREFIX=/api
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_MAX_REQUESTS=60
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_TABLE=api_rate_limits
API_TOKEN_TABLE=users_access_tokens
API_LOG_ERRORS=true
API_LOGGING_ENABLED=false
API_LOG_PATH=logs/api.log
API_IP_WHITELIST=127.0.0.1,::1
API_URL_WHITELIST=/api/v1/auth/login
API_CORS_ALLOW_ORIGIN=*
API_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
API_CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With
API_CORS_ALLOW_CREDENTIALS=false
API_CORS_ALLOW_WILDCARD_WITH_AUTH=false

# Auth defaults (session-first)
AUTH_METHODS=session
AUTH_API_METHODS=token
AUTH_SOCIALITE_ENABLED=true

AUTH_SESSION_SECURITY_ENABLED=true
AUTH_SESSION_BIND_USER_AGENT=true
AUTH_SESSION_USER_AGENT_MODE=strict
AUTH_SESSION_BIND_IP=false
AUTH_SESSION_FINGERPRINT_KEY=_auth_fp
AUTH_DEBUG_LOG_ENABLED=false

AUTH_SESSION_CONCURRENCY_ENABLED=false
AUTH_SESSION_MAX_DEVICES=0
AUTH_SESSION_INVALIDATE_OLDEST=true
AUTH_SESSION_DENY_WHEN_LIMIT=false
AUTH_SESSION_CONCURRENCY_TTL=2592000
AUTH_SESSION_ENFORCE_ON_CHECK=true
AUTH_SESSION_FAIL_OPEN=true
AUTH_SESSION_CACHE_PREFIX=auth_sessions_
AUTH_SESSION_STORE_FINGERPRINT=true

AUTH_LOGIN_POLICY_ENABLED=true
AUTH_LOGIN_POLICY_MAX_ATTEMPTS=5
AUTH_LOGIN_POLICY_DECAY_SECONDS=600
AUTH_LOGIN_POLICY_LOCKOUT_SECONDS=900
AUTH_LOGIN_POLICY_BAN_ENABLED=false
AUTH_LOGIN_POLICY_BAN_AFTER_FAILURES=5
AUTH_LOGIN_POLICY_BAN_USER_STATUS=2
AUTH_LOGIN_POLICY_TRACK_IDENTIFIER=true
AUTH_LOGIN_POLICY_TRACK_IP=true
AUTH_LOGIN_POLICY_IDENTIFIER_FIELDS=email,username
AUTH_LOGIN_POLICY_CACHE_PREFIX=auth_login_policy_
AUTH_LOGIN_POLICY_FAIL_OPEN=true
AUTH_LOGIN_POLICY_RECORD_ATTEMPTS=true
AUTH_LOGIN_POLICY_RECORD_HISTORY=true
AUTH_LOGIN_POLICY_ENFORCE_USER_STATUS=true
AUTH_LOGIN_POLICY_ALLOWED_STATUS=1
AUTH_PASSWORD_ROTATION_ENABLED=false
AUTH_PASSWORD_MAX_AGE_DAYS=90
AUTH_PASSWORD_CHANGED_AT_COLUMN=password_changed_at
AUTH_PASSWORD_FORCE_RESET_COLUMN=force_password_change
AUTH_PASSWORD_REQUIRE_CHANGED_AT=false

AUTH_JWT_ENABLED=false
AUTH_JWT_ALGO=HS256
AUTH_JWT_SECRET=
AUTH_JWT_LEEWAY=60
AUTH_JWT_USER_ID_CLAIM=sub

AUTH_API_KEY_ENABLED=false
AUTH_API_KEY_HEADER=X-API-KEY
AUTH_API_KEY_QUERY_PARAM=api_key
AUTH_API_KEY_ALLOW_QUERY_PARAM=false

AUTH_OAUTH2_ENABLED=false
AUTH_OAUTH2_HASH_TOKENS=true
AUTH_OAUTH2_HEADER_PREFIX=Bearer

AUTH_BASIC_ENABLED=false
AUTH_BASIC_REALM=MythPHP
AUTH_BASIC_IDENTIFIER_COLUMNS=username,email

AUTH_DIGEST_ENABLED=false
AUTH_DIGEST_REALM=MythPHP API
AUTH_DIGEST_QOP=auth
AUTH_DIGEST_NONCE_SECRET=
AUTH_DIGEST_NONCE_TTL=300
AUTH_DIGEST_NONCE_FUTURE_SKEW=30
AUTH_DIGEST_USERNAME_COLUMN=username
AUTH_DIGEST_HA1_COLUMN=digest_ha1

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=MythPHP
MAIL_DEBUG=false

# Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
