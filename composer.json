{
    "description": "MythPHP using native PHP",
    "name": "faizzul95/mythphp",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\Http\\Controllers\\": "app/http/controllers/",
            "App\\Http\\Middleware\\": "app/http/middleware/",
            "App\\Http\\Requests\\": "app/http/requests/",
            "App\\Http\\": "app/http/",
            "App\\Console\\": "app/console/",
            "App\\Providers\\": "app/providers/",
            "App\\Support\\": "app/support/",
            "App\\": "app/",
            "Core\\": "systems/Core/",
            "Components\\": "systems/Components/",
            "Middleware\\": "systems/Middleware/"
        }
    },
    "config": {
        "process-timeout": 4000,
        "optimize-autoloader": true,
        "classmap-authoritative": false,
        "sort-packages": true
    },
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^6.10",
        "google/apiclient": "^2.18"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^1.12",
        "roave/security-advisories": "dev-latest"
    }
}
